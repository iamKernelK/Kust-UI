        ImageFrame.LayoutOrder = 2

        local ImageLabel = Instance.new("ImageLabel", ImageFrame)
        ImageLabel.Size = UDim2.new(1, 0, 1, 0)
        ImageLabel.BackgroundTransparency = 1
        ImageLabel.Image = ImageId
        ImageLabel.ScaleType = Enum.ScaleType.Crop
        Instance.new("UICorner", ImageLabel).CornerRadius = UDim.new(0, 8)
    end

    local ContentLabel = Instance.new("TextLabel", ParagraphFrame)
    ContentLabel.Size = UDim2.new(1, 0, 0, 0)
    ContentLabel.BackgroundTransparency = 1
    ContentLabel.Text = Content
    ContentLabel.TextColor3 = theme.TextDim
    ContentLabel.Font = Enum.Font.GothamMedium
    ContentLabel.TextSize = 13
    ContentLabel.TextXAlignment = Enum.TextXAlignment.Left
    ContentLabel.TextWrapped = true
    ContentLabel.AutomaticSize = Enum.AutomaticSize.Y
    ContentLabel.LayoutOrder = 3

    if ButtonText then
        local BtnContainer = Instance.new("Frame", ParagraphFrame)
        BtnContainer.Size = UDim2.new(1, 0, 0, 38)
        BtnContainer.BackgroundTransparency = 1
        BtnContainer.LayoutOrder = 4

        local ActionBtn = Instance.new("TextButton", BtnContainer)
        ActionBtn.Size = UDim2.new(1, 0, 0, 36)
        ActionBtn.Position = UDim2.new(0, 0, 0.5, -18)
        ActionBtn.BackgroundColor3 = theme.Primary
        ActionBtn.Text = ""
        ActionBtn.AutoButtonColor = false
        Instance.new("UICorner", ActionBtn).CornerRadius = UDim.new(0, 8)

        local BtnGradient = Instance.new("UIGradient", ActionBtn)
        BtnGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, theme.PrimaryLight),
            ColorSequenceKeypoint.new(1, theme.PrimaryDark)
        })
        BtnGradient.Rotation = 90

        local btnTextOffset = 0
        if ButtonIcon then
            local BIcon = Instance.new("ImageLabel", ActionBtn)
            BIcon.Size = UDim2.new(0, 18, 0, 18)
            BIcon.Position = UDim2.new(0.5, -40, 0.5, -9)
            BIcon.BackgroundTransparency = 1
            BIcon.Image = ButtonIcon
            BIcon.ImageColor3 = Color3.new(1, 1, 1)
            btnTextOffset = 20
        end

        local BtnText = Instance.new("TextLabel", ActionBtn)
        BtnText.Size = UDim2.new(1, 0, 1, 0)
        BtnText.Position = UDim2.new(0, btnTextOffset, 0, 0)
        BtnText.BackgroundTransparency = 1
        BtnText.Text = ButtonText
        BtnText.TextColor3 = Color3.new(1, 1, 1)
        BtnText.Font = Enum.Font.GothamBold
        BtnText.TextSize = 13

        ActionBtn.MouseEnter:Connect(function()
            TweenService:Create(ActionBtn, TweenInfo.new(0.2), {BackgroundColor3 = theme.PrimaryLight}):Play()
        end)
        ActionBtn.MouseLeave:Connect(function()
            TweenService:Create(ActionBtn, TweenInfo.new(0.2), {BackgroundColor3 = theme.Primary}):Play()
        end)
        ActionBtn.MouseButton1Click:Connect(function()
            TweenService:Create(ActionBtn, TweenInfo.new(0.1), {Size = UDim2.new(0.98, 0, 0, 34)}):Play()
            task.wait(0.1)
            TweenService:Create(ActionBtn, TweenInfo.new(0.2, Enum.EasingStyle.Back), {Size = UDim2.new(1, 0, 0, 36)}):Play()
            ButtonCallback()
        end)
    end

    ParagraphFrame.MouseEnter:Connect(function()
        TweenService:Create(ParagraphFrame, TweenInfo.new(0.2), {BackgroundColor3 = theme.SurfaceHover}):Play()
    end)
    ParagraphFrame.MouseLeave:Connect(function()
        TweenService:Create(ParagraphFrame, TweenInfo.new(0.2), {BackgroundColor3 = theme.Surface}):Play()
    end)

    if Options.Locked then
        LockModule.Apply(ParagraphFrame, Options)
    end

    return ParagraphFrame
end

