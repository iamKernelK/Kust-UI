    QuickFrame.ZIndex = 9999
    QuickFrame.Parent = ScreenGui
    Instance.new("UICorner", QuickFrame).CornerRadius = UDim.new(1, 0)

    local QuickStroke = Instance.new("UIStroke", QuickFrame)
    QuickStroke.Color = theme.Primary
    QuickStroke.Thickness = 2
    ApplyGradient(QuickStroke)

    local QuickIcon = Instance.new("ImageLabel", QuickFrame)
    QuickIcon.Size = UDim2.new(0, 30, 0, 30)
    QuickIcon.Position = UDim2.new(0.5, 0, 0.5, 0)
    QuickIcon.AnchorPoint = Vector2.new(0.5, 0.5)
    QuickIcon.BackgroundTransparency = 1
    QuickIcon.Image = Config.Icon or "rbxassetid://107150227368485"
    QuickIcon.ImageColor3 = theme.Primary

    local QuickText = Instance.new("TextLabel", QuickFrame)
    QuickText.Size = UDim2.new(1, 0, 0, 14)
    QuickText.Position = UDim2.new(0, 0, 1, 2)
    QuickText.BackgroundTransparency = 1
    QuickText.Text = Config.Name or "Quick"
    QuickText.TextColor3 = theme.Text
    QuickText.Font = Enum.Font.GothamBold
    QuickText.TextSize = 10
    QuickText.TextStrokeTransparency = 0.8

    MakeDraggable(QuickFrame, QuickFrame)

    local pulseTween = TweenService:Create(QuickStroke, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {Transparency = 0.3})
    pulseTween:Play()

    local ClickBtn = Instance.new("TextButton", QuickFrame)
    ClickBtn.Size = UDim2.new(1, 0, 1, 0)
    ClickBtn.BackgroundTransparency = 1
    ClickBtn.Text = ""
    ClickBtn.ZIndex = 99999

    if Config.Type == "Toggle" then
        local toggled = Config.Default or false
        QuickIcon.ImageColor3 = toggled and theme.Success or theme.Primary
        ClickBtn.MouseButton1Click:Connect(function()
            toggled = not toggled
            QuickIcon.ImageColor3 = toggled and theme.Success or theme.Primary
            if Config.Callback then Config.Callback(toggled) end
        end)
    elseif Config.Type == "Button" then
        ClickBtn.MouseButton1Click:Connect(function()
            TweenService:Create(QuickFrame, TweenInfo.new(0.1), {Size = UDim2.new(0, 55, 0, 55)}):Play()
            task.wait(0.1)
            TweenService:Create(QuickFrame, TweenInfo.new(0.2, Enum.EasingStyle.Back), {Size = UDim2.new(0, 60, 0, 60)}):Play()
            if Config.Callback then Config.Callback() end
        end)
    elseif Config.Type == "Slider" then
        local SliderBg = Instance.new("Frame", QuickFrame)
        SliderBg.Size = UDim2.new(0.8, 0, 0, 4)
        SliderBg.Position = UDim2.new(0.1, 0, 0.85, 0)
        SliderBg.BackgroundColor3 = theme.Background
        SliderBg.BorderSizePixel = 0
        Instance.new("UICorner", SliderBg).CornerRadius = UDim.new(1, 0)

        local SliderFill = Instance.new("Frame", SliderBg)
        SliderFill.Size = UDim2.new(0.5, 0, 1, 0)
        SliderFill.BackgroundColor3 = theme.Primary
        SliderFill.BorderSizePixel = 0
        Instance.new("UICorner", SliderFill).CornerRadius = UDim.new(1, 0)

        local dragging = false
        ClickBtn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                local relX = math.clamp((input.Position.X - SliderBg.AbsolutePosition.X) / SliderBg.AbsoluteSize.X, 0, 1)
                SliderFill.Size = UDim2.new(relX, 0, 1, 0)
                local val = math.floor(((Config.Max or 100) - (Config.Min or 0)) * relX + (Config.Min or 0))
                if Config.Callback then Config.Callback(val) end
            end
        end)
    end

    QuickFrame.Size = UDim2.new(0, 0, 0, 0)
    TweenService:Create(QuickFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 60, 0, 60)}):Play()

    table.insert(self.ActiveButtons, QuickFrame)
    return QuickFrame
end

