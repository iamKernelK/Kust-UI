        local dragStartX, dragStartY
        local isDragging = false
        local dragThreshold = 15

        InteractBtn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragStartX = input.Position.X
                dragStartY = input.Position.Y
                isDragging = false
            end
        end)

        InteractBtn.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                if dragStartX then
                    local deltaX = input.Position.X - dragStartX
                    local deltaY = input.Position.Y - dragStartY
                    if math.abs(deltaX) > 5 or math.abs(deltaY) > 5 then
                        isDragging = true
                        local liftAmount = math.clamp(math.abs(deltaX) / 150, 0, 0.12)
                        local liftY = math.clamp(-math.abs(deltaY) * 0.15, -8, 0)
                        TweenService:Create(ToggleFrame, TweenInfo.new(0.08), {
                            Position = UDim2.new(originalPos.X.Scale, originalPos.X.Offset, originalPos.Y.Scale, originalPos.Y.Offset + liftY),
                            BackgroundTransparency = liftAmount
                        }):Play()
                    end
                end
            end
        end)

        InteractBtn.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                TweenService:Create(ToggleFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
                    Position = originalPos,
                    BackgroundTransparency = 0
                }):Play()

                if dragStartX then
                    local deltaX = input.Position.X - dragStartX
                    if math.abs(deltaX) > dragThreshold then
                        if deltaX > 0 and not State then
                            State = true; Update(); Callback(State)
                        elseif deltaX < 0 and State then
                            State = false; Update(); Callback(State)
                        end
                    elseif not isDragging then
                        State = not State; Update(); Callback(State)
                    end
                end
                dragStartX = nil
                isDragging = false
            end
        end)

        Update()
    else
        local Pill = Instance.new("Frame", ToggleFrame)
        Pill.Size = UDim2.new(0, 48, 0, 24)
        Pill.Position = UDim2.new(1, rightOffset, 0.5, 0)
        Pill.AnchorPoint = Vector2.new(1, 0.5)
        Pill.BackgroundColor3 = Color3.fromRGB(40, 35, 35)
        Instance.new("UICorner", Pill).CornerRadius = UDim.new(1, 0)

        local Circle = Instance.new("Frame", Pill)
        Circle.Size = UDim2.new(0, 20, 0, 20)
        Circle.Position = UDim2.new(0, 2, 0.5, 0)
        Circle.AnchorPoint = Vector2.new(0, 0.5)
        Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

        local function Update()
            local targetBg = State and theme.Primary or Color3.fromRGB(40, 35, 35)
            local targetPos = State and UDim2.new(1, -22, 0.5, 0) or UDim2.new(0, 2, 0.5, 0)
            TweenService:Create(Pill, TweenInfo.new(0.3), {BackgroundColor3 = targetBg}):Play()
            TweenService:Create(Circle, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = targetPos}):Play()
        end

        local dragStartX, dragStartY
        local isDragging = false

        InteractBtn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragStartX = input.Position.X
                dragStartY = input.Position.Y
                isDragging = false
            end
        end)

        InteractBtn.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                if dragStartX then
                    local deltaX = input.Position.X - dragStartX
                    local deltaY = input.Position.Y - dragStartY
                    if math.abs(deltaX) > 5 or math.abs(deltaY) > 5 then
                        isDragging = true
                        local liftAmount = math.clamp(math.abs(deltaX) / 150, 0, 0.12)
                        local liftY = math.clamp(-math.abs(deltaY) * 0.15, -8, 0)
                        TweenService:Create(ToggleFrame, TweenInfo.new(0.08), {
                            Position = UDim2.new(originalPos.X.Scale, originalPos.X.Offset, originalPos.Y.Scale, originalPos.Y.Offset + liftY),
                            BackgroundTransparency = liftAmount
                        }):Play()
                    end
                end
            end
        end)

        InteractBtn.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                TweenService:Create(ToggleFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
                    Position = originalPos,
                    BackgroundTransparency = 0
                }):Play()

                if dragStartX then
                    local deltaX = input.Position.X - dragStartX
                    if math.abs(deltaX) > 15 then
                        if deltaX > 0 and not State then
                            State = true; Update(); Callback(State)
                        elseif deltaX < 0 and State then
                            State = false; Update(); Callback(State)
                        end
                    elseif not isDragging then
                        State = not State; Update(); Callback(State)
                    end
                end
                dragStartX = nil
                isDragging = false
            end
        end)

        Update()
    end

    InteractBtn.MouseEnter:Connect(function()
        TweenService:Create(ToggleFrame, TweenInfo.new(0.2), {BackgroundColor3 = theme.SurfaceHover}):Play()
    end)
    InteractBtn.MouseLeave:Connect(function()
        TweenService:Create(ToggleFrame, TweenInfo.new(0.2), {BackgroundColor3 = theme.Surface}):Play()
    end)

    if Options.Locked then
        LockModule.Apply(ToggleFrame, Options)
    end

    return ToggleFrame
end

