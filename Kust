function KustUI.CreateWindow(Options)
    local self = setmetatable({}, KustUI)
    local theme = Options.Theme or KustUI.Themes.Default
    if type(theme) == "string" then theme = KustUI.Themes[theme] or KustUI.Themes.Default end
    self.Theme = theme

    local TitleText = Options.Title or "Kust UI"
    local DescText = Options.Description or "Premium Library"
    local ThemeImage = Options.ThemeImage or "rbxassetid://103845371952278"

    -- ScreenGui
    self.ScreenGui = Instance.new("ScreenGui")
    self.ScreenGui.Name = "KustUI_Premium"
    self.ScreenGui.ResetOnSpawn = false
    self.ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Global
    pcall(function() self.ScreenGui.Parent = gethui() end)
    if not self.ScreenGui.Parent then pcall(function() self.ScreenGui.Parent = CoreGui end) end
    if not self.ScreenGui.Parent then self.ScreenGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui") end

    -- Main Frame
    self.MainFrame = Instance.new("Frame")
    self.MainFrame.Size = UDim2.new(0, 0, 0, 0)
    self.MainFrame.AnchorPoint = Vector2.new(0.5, 0.5)
