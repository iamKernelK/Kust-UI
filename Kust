        TweenService:Create(Button, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {BackgroundColor3 = theme.Surface}):Play()
        TweenService:Create(Stroke, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Thickness = 1, Transparency = 0.7}):Play()
    end)

    Button.MouseButton1Down:Connect(function()
        local Mouse = Players.LocalPlayer:GetMouse()
        local X, Y = Mouse.X - Button.AbsolutePosition.X, Mouse.Y - Button.AbsolutePosition.Y
        CreateRipple(ClipContainer, Vector2.new(X, Y))
    end)

    local holdStart = 0
    local holding = false

    Button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            holding = true
            holdStart = tick()
            TweenService:Create(Button, TweenInfo.new(0.2), {BackgroundColor3 = theme.PrimaryDark}):Play()
            task.spawn(function()
                while holding do
                    if tick() - holdStart >= 3 then
                        holding = false
                        if quickConfig then
                            QuickButtonModule:CreateFromElement(Button, quickConfig)
                        end
                        TweenService:Create(Button, TweenInfo.new(0.3), {BackgroundColor3 = theme.Surface}):Play()
                        break
                    end
                    task.wait(0.1)
                end
            end)
        end
    end)

    Button.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            holding = false
            TweenService:Create(Button, TweenInfo.new(0.3), {BackgroundColor3 = theme.Surface}):Play()
            if tick() - holdStart < 3 then
                callback()
            end
        end
    end)

    if Options.Locked then
        LockModule.Apply(Button, Options)
    end

    return Button
end

