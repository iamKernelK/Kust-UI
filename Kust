    Stroke.Transparency = 0.8
    Stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    local Header = Instance.new("Frame", SliderContainer)
    Header.Size = UDim2.new(1, -20, 0, 24)
    Header.Position = UDim2.new(0, 10, 0, 6)
    Header.BackgroundTransparency = 1

    local TitleOffset = 5
    if IconID then
        local Icon = Instance.new("ImageLabel", Header)
        Icon.Size = UDim2.new(0, 16, 0, 16)
        Icon.Position = UDim2.new(0, 5, 0.5, -8)
        Icon.BackgroundTransparency = 1
        Icon.Image = IconID
        Icon.ImageColor3 = theme.Primary
        TitleOffset = 26
    end

    local TitleLabel = Instance.new("TextLabel", Header)
    TitleLabel.Size = UDim2.new(1, -60, 1, 0)
    TitleLabel.Position = UDim2.new(0, TitleOffset, 0, 0)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = Name
    TitleLabel.TextColor3 = theme.Text
    TitleLabel.Font = Enum.Font.GothamSemibold
    TitleLabel.TextSize = 13
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

    local ValueDisplay = Instance.new("TextLabel", Header)
    ValueDisplay.Size = UDim2.new(0, 50, 1, 0)
    ValueDisplay.Position = UDim2.new(1, -5, 0, 0)
    ValueDisplay.AnchorPoint = Vector2.new(1, 0)
    ValueDisplay.BackgroundTransparency = 1
    ValueDisplay.Text = tostring(Default)
    ValueDisplay.TextColor3 = theme.Primary
    ValueDisplay.Font = Enum.Font.GothamBold
    ValueDisplay.TextSize = 13
    ValueDisplay.TextXAlignment = Enum.TextXAlignment.Right

    local TrackArea = Instance.new("Frame", SliderContainer)
    TrackArea.Size = UDim2.new(1, -20, 0, 20)
    TrackArea.Position = UDim2.new(0, 10, 0, 30)
    TrackArea.BackgroundTransparency = 1

    local Track = Instance.new("Frame", TrackArea)
    Track.Size = UDim2.new(1, 0, 0, 5)
    Track.Position = UDim2.new(0, 0, 0.5, -2.5)
    Track.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

    local Fill = Instance.new("Frame", Track)
    Fill.Size = UDim2.new((Default - Min) / (Max - Min), 0, 1, 0)
    Fill.BackgroundColor3 = theme.Primary
    Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

    local Thumb = Instance.new("ImageLabel", Track)
    Thumb.Size = UDim2.new(0, 16, 0, 16)
    Thumb.Position = UDim2.new((Default - Min) / (Max - Min), 0, 0.5, 0)
    Thumb.AnchorPoint = Vector2.new(0.5, 0.5)
    Thumb.BackgroundTransparency = 1
    Thumb.Image = "rbxassetid://125083578015333"
    Thumb.ImageColor3 = theme.Text
    Thumb.ScaleType = Enum.ScaleType.Fit

    local Dragging = false
    local TargetPct = (Default - Min) / (Max - Min)
    local CurrentPct = TargetPct
    local Mouse = Players.LocalPlayer:GetMouse()
    local originalPos = SliderContainer.Position

    Thumb.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            Dragging = true
            TweenService:Create(Thumb, TweenInfo.new(0.2), {Size = UDim2.new(0, 20, 0, 20)}):Play()
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if Dragging then
                Dragging = false
                TweenService:Create(Thumb, TweenInfo.new(0.2), {Size = UDim2.new(0, 16, 0, 16)}):Play()
                TweenService:Create(SliderContainer, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
                    Position = originalPos,
                    BackgroundTransparency = 0
                }):Play()
            end
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if Dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local pos = math.clamp((Mouse.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
            TargetPct = pos

            local deltaY = input.Position.Y - (Track.AbsolutePosition.Y + Track.AbsoluteSize.Y/2)
            local liftAmount = math.clamp(-math.abs(deltaY) * 0.008, -6, 0)
            local transparency = math.clamp(math.abs(deltaY) * 0.003, 0, 0.15)

            TweenService:Create(SliderContainer, TweenInfo.new(0.08), {
                Position = UDim2.new(originalPos.X.Scale, originalPos.X.Offset, originalPos.Y.Scale, originalPos.Y.Offset + liftAmount),
                BackgroundTransparency = transparency
            }):Play()
        end
    end)

    RunService.RenderStepped:Connect(function()
        CurrentPct = CurrentPct + (TargetPct - CurrentPct) * 0.4
        if math.abs(TargetPct - CurrentPct) < 0.001 then CurrentPct = TargetPct end

        Thumb.Position = UDim2.new(CurrentPct, 0, 0.5, 0)
        Fill.Size = UDim2.new(CurrentPct, 0, 1, 0)

        local rawVal = Min + (CurrentPct * (Max - Min))
        local val = math.floor(rawVal / Increment + 0.5) * Increment
        ValueDisplay.Text = tostring(val)

        if Dragging or math.abs(TargetPct - CurrentPct) > 0.001 then
            Callback(val)
        end
    end)

    if Options.Locked then
        LockModule.Apply(SliderContainer, Options)
    end

    return SliderContainer
end

