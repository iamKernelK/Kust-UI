        TweenService:Create(Title, TweenInfo.new(0.3), {TextColor3 = theme.Text}):Play()
        local currentIcon = TabButton:FindFirstChildOfClass("ImageLabel")
        if currentIcon then TweenService:Create(currentIcon, TweenInfo.new(0.3), {ImageColor3 = theme.Primary}):Play() end
