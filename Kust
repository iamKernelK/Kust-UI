function KustUI:AddTab(Options)
    local theme = self.Theme
    local Name = Options.Name or "Tab"
    local IconId = Options.Icon

    local isFirst = true
    for _, v in ipairs(self.ElementsMenu:GetChildren()) do
        if v.Name:match("_Container") then isFirst = false; break end
    end

    local TAB_BG = Color3.fromRGB(20, 15, 12)
    local TAB_HOVER = Color3.fromRGB(30, 20, 15)
    local TAB_SELECTED = Color3.fromRGB(45, 25, 10)
    local TEXT_COLOR = Color3.fromRGB(180, 180, 180)
    local TEXT_SELECTED = Color3.fromRGB(255, 255, 255)

    local TabButton = Instance.new("TextButton")
    TabButton.Name = Name .. "_TabBtn"
    TabButton.Size = UDim2.new(1, 0, 0, 38)
    TabButton.BackgroundColor3 = isFirst and TAB_SELECTED or TAB_BG
    TabButton.Text = ""
    TabButton.AutoButtonColor = false
    TabButton.ClipsDescendants = true
    TabButton.Parent = self.TabsMenu
    Instance.new("UICorner", TabButton).CornerRadius = UDim.new(0, 8)
    local btnStroke = Instance.new("UIStroke", TabButton)
    btnStroke.Color = theme.Primary
    btnStroke.Thickness = 1
    btnStroke.Transparency = isFirst and 0 or 1
    btnStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    local textOffset = 15
    if IconId then
        local icon = Instance.new("ImageLabel", TabButton)
        icon.Size = UDim2.new(0, 16, 0, 16)
        icon.Position = UDim2.new(0, 12, 0.5, 0)
        icon.AnchorPoint = Vector2.new(0, 0.5)
        icon.BackgroundTransparency = 1
        icon.Image = IconId
        icon.ImageColor3 = isFirst and theme.Primary or TEXT_COLOR
        textOffset = 36
    end

    local Title = Instance.new("TextLabel", TabButton)
    Title.Size = UDim2.new(1, -textOffset, 1, 0)
    Title.Position = UDim2.new(0, textOffset, 0, 0)
    Title.BackgroundTransparency = 1
    Title.Text = Name
    Title.TextColor3 = isFirst and TEXT_SELECTED or TEXT_COLOR
    Title.Font = Enum.Font.GothamMedium
    Title.TextSize = 13
    Title.TextXAlignment = Enum.TextXAlignment.Left

    local TabContainer = Instance.new("ScrollingFrame")
    TabContainer.Name = Name .. "_Container"
    TabContainer.Size = UDim2.new(1, 0, 1, 0)
    TabContainer.BackgroundTransparency = 1
    TabContainer.ScrollBarThickness = 0
    TabContainer.Visible = isFirst
    TabContainer.ClipsDescendants = true
    TabContainer.Parent = self.ElementsMenu

    local pad = Instance.new("UIPadding", TabContainer)
    pad.PaddingTop = UDim.new(0, 12)
    pad.PaddingBottom = UDim.new(0, 12)
    pad.PaddingLeft = UDim.new(0, 12)
    pad.PaddingRight = UDim.new(0, 12)
    local layout = Instance.new("UIListLayout", TabContainer)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 8)

    TabButton.MouseButton1Click:Connect(function()
        if TabContainer.Visible then return end
        for _, c in ipairs(self.ElementsMenu:GetChildren()) do
            if c:IsA("ScrollingFrame") then c.Visible = false end
        end
        for _, b in ipairs(self.TabsMenu:GetChildren()) do
            if b:IsA("TextButton") then
                TweenService:Create(b, TweenInfo.new(0.25), {BackgroundColor3 = TAB_BG}):Play()
                TweenService:Create(b:FindFirstChild("UIStroke"), TweenInfo.new(0.25), {Transparency = 1}):Play()
                local txt = b:FindFirstChildOfClass("TextLabel")
                if txt then TweenService:Create(txt, TweenInfo.new(0.25), {TextColor3 = TEXT_COLOR}):Play() end
                local ic = b:FindFirstChildOfClass("ImageLabel")
                if ic then TweenService:Create(ic, TweenInfo.new(0.25), {ImageColor3 = TEXT_COLOR}):Play() end
            end
        end
        TabContainer.Visible = true
        TweenService:Create(TabButton, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundColor3 = TAB_SELECTED}):Play()
        TweenService:Create(btnStroke, TweenInfo.new(0.3), {Transparency = 0}):Play()
        TweenService:Create(Title, TweenInfo.new(0.3), {TextColor3 = TEXT_SELECTED}):Play()
        local curIcon = TabButton:FindFirstChildOfClass("ImageLabel")
        if curIcon then TweenService:Create(curIcon, TweenInfo.new(0.3), {ImageColor3 = theme.Primary}):Play() end
    end)

    TabButton.MouseEnter:Connect(function()
        if not TabContainer.Visible then TweenService:Create(TabButton, TweenInfo.new(0.2), {BackgroundColor3 = TAB_HOVER}):Play() end
    end)
    TabButton.MouseLeave:Connect(function()
        if not TabContainer.Visible then TweenService:Create(TabButton, TweenInfo.new(0.2), {BackgroundColor3 = TAB_BG}):Play() end
    end)

    return TabContainer
end

-- ============================================================
-- ADD BUTTON (with Hold 3s -> QuickButton)
-- ============================================================
function KustUI:AddButton(Tab, Options)
    local theme = self.Theme
    local text = Options.Name or "Button"
    local callback = Options.Callback or function() end
    local iconId = Options.Icon or "rbxassetid://107150227368485"
    local holdCallback = Options.HoldCallback or function() end

    local Button = Instance.new("TextButton")
    Button.Name = text .. "_Btn"
    Button.Size = UDim2.new(1, 0, 0, 44)
    Button.BackgroundColor3 = theme.ElementBg
    Button.Text = ""
    Button.AutoButtonColor = false
    Button.Parent = Tab
    Instance.new("UICorner", Button).CornerRadius = UDim.new(0, 8)

    local btnGrad = Instance.new("UIGradient", Button)
    btnGrad.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(190,190,190))})
    btnGrad.Rotation = 90

    local clip = Instance.new("Frame", Button)
    clip.Size = UDim2.new(1, 0, 1, 0)
    clip.BackgroundTransparency = 1
    clip.ClipsDescendants = true
    Instance.new("UICorner", clip).CornerRadius = UDim.new(0, 8)

    local btnStroke = Instance.new("UIStroke", Button)
    btnStroke.Color = theme.Primary
    btnStroke.Thickness = 1
    btnStroke.Transparency = 0.7
    btnStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    local Title = Instance.new("TextLabel", Button)
    Title.Size = UDim2.new(1, -55, 1, 0)
    Title.Position = UDim2.new(0, 16, 0, 0)
    Title.BackgroundTransparency = 1
    Title.Text = text
    Title.TextColor3 = theme.Primary
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 13.5
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.ZIndex = 2

    local RightIcon = Instance.new("ImageLabel", Button)
    RightIcon.Size = UDim2.new(0, 18, 0, 18)
    RightIcon.Position = UDim2.new(1, -16, 0.5, 0)
    RightIcon.AnchorPoint = Vector2.new(1, 0.5)
    RightIcon.BackgroundTransparency = 1
    RightIcon.Image = iconId
    RightIcon.ImageColor3 = theme.Primary
    RightIcon.ZIndex = 2

    -- Hover
    Button.MouseEnter:Connect(function()
        TweenService:Create(Button, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {BackgroundColor3 = theme.ElementHover}):Play()
        TweenService:Create(btnStroke, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {Thickness = 1.6, Transparency = 0.2}):Play()
    end)
    Button.MouseLeave:Connect(function()
        TweenService:Create(Button, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {BackgroundColor3 = theme.ElementBg}):Play()
        TweenService:Create(btnStroke, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Thickness = 1, Transparency = 0.7}):Play()
    end)

    -- Ripple
    Button.MouseButton1Down:Connect(function()
        local mouse = Players.LocalPlayer:GetMouse()
        local X, Y = mouse.X - Button.AbsolutePosition.X, mouse.Y - Button.AbsolutePosition.Y
        local ripple = Instance.new("Frame", clip)
        ripple.BackgroundColor3 = theme.Primary
        ripple.BackgroundTransparency = 0.4
        ripple.Position = UDim2.new(0, X, 0, Y)
        ripple.AnchorPoint = Vector2.new(0.5, 0.5)
        Instance.new("UICorner", ripple).CornerRadius = UDim.new(1, 0)
        local ts = math.max(Button.AbsoluteSize.X, Button.AbsoluteSize.Y) * 1.6
        TweenService:Create(ripple, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, ts, 0, ts), BackgroundTransparency = 1}):Play()
        task.delay(0.45, function() ripple:Destroy() end)
    end)

    -- Hold 3s -> QuickButton
    local holding = false
    local holdStart = 0
    local quickBtn = nil
    local holdConn = nil

    Button.MouseButton1Down:Connect(function()
        holding = true
        holdStart = tick()
        if holdConn then holdConn:Disconnect() end
        holdConn = RunService.RenderStepped:Connect(function()
            if holding and (tick() - holdStart) >= 3 then
                holding = false
                holdConn:Disconnect()
                -- Spawn QuickButton
                if quickBtn then quickBtn:Destroy() end
                quickBtn = Instance.new("ImageButton")
                quickBtn.Name = text .. "_Quick"
                quickBtn.Size = UDim2.new(0, 0, 0, 0)
                quickBtn.AnchorPoint = Vector2.new(0.5, 0.5)
                quickBtn.Position = UDim2.new(0.5, 0, 0.8, 0)
                quickBtn.BackgroundColor3 = Color3.fromRGB(15, 8, 5)
                quickBtn.AutoButtonColor = false
                quickBtn.Parent = self.ScreenGui
                quickBtn.ZIndex = 200
                Instance.new("UICorner", quickBtn).CornerRadius = UDim.new(1, 0)
                local qIcon = Instance.new("ImageLabel", quickBtn)
                qIcon.Size = UDim2.new(0.7, 0, 0.7, 0)
                qIcon.Position = UDim2.new(0.5, 0, 0.5, 0)
                qIcon.AnchorPoint = Vector2.new(0.5, 0.5)
                qIcon.BackgroundTransparency = 1
                qIcon.Image = iconId
                qIcon.ImageColor3 = theme.Primary
                local qStroke = Instance.new("UIStroke", quickBtn)
                qStroke.Thickness = 2
                qStroke.Color = Color3.new(1,1,1)
                ApplyGradient(qStroke, theme)
                MakeDraggable(quickBtn, quickBtn)
                TweenService:Create(quickBtn, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 55, 0, 55)}):Play()
                quickBtn.MouseButton1Click:Connect(function()
                    callback()
                    TweenService:Create(quickBtn, TweenInfo.new(0.3), {Size = UDim2.new(0, 45, 0, 45)}):Play()
                    task.wait(0.15)
                    TweenService:Create(quickBtn, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 55, 0, 55)}):Play()
                end)
                holdCallback(quickBtn)
            end
        end)
    end)

    Button.MouseButton1Up:Connect(function()
        if holding and (tick() - holdStart) < 3 then
            holding = false
            if holdConn then holdConn:Disconnect() end
            callback()
        else
            holding = false
            if holdConn then holdConn:Disconnect() end
        end
    end)

    ApplyLock(Button, Options, theme)
    return Button
end

-- ============================================================
-- ADD TOGGLE (Drag Right = ON, Lift Effect)
-- ============================================================
function KustUI:AddToggle(Tab, Options)
    local theme = self.Theme
    local TName = Options.Name or "Toggle"
    local TType = string.lower(Options.Type or "default")
    local State = Options.Default or false
    local Callback = Options.Callback or function() end
    local IconId = Options.Icon
    local Pos = Options.Pos or "None"
    local hasLeft = (Pos == "Left" or Pos == "Both") and IconId ~= nil
    local hasRight = (Pos == "Right" or Pos == "Both") and IconId ~= nil

    local ToggleFrame = Instance.new("Frame")
    ToggleFrame.Name = TName .. "_Toggle"
    ToggleFrame.Size = UDim2.new(1, 0, 0, 42)
    ToggleFrame.BackgroundColor3 = theme.ElementBg
    ToggleFrame.Parent = Tab
    Instance.new("UICorner", ToggleFrame).CornerRadius = UDim.new(0, 8)

    local stroke = Instance.new("UIStroke", ToggleFrame)
    stroke.Color = theme.Primary
    stroke.Thickness = 1
    stroke.Transparency = 0.8
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    TweenService:Create(stroke, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {Transparency = 0.2}):Play()

    local InteractBtn = Instance.new("TextButton", ToggleFrame)
    InteractBtn.Size = UDim2.new(1, 0, 1, 0)
    InteractBtn.BackgroundTransparency = 1
    InteractBtn.Text = ""

    local titleOffset = 15
    if hasLeft then
        local li = Instance.new("ImageLabel", ToggleFrame)
        li.Size = UDim2.new(0, 20, 0, 20)
        li.Position = UDim2.new(0, 15, 0.5, 0)
        li.AnchorPoint = Vector2.new(0, 0.5)
        li.BackgroundTransparency = 1
        li.Image = IconId
        li.ImageColor3 = theme.Primary
        titleOffset = 45
    end
    local rightOffset = -15
    if hasRight then
        local ri = Instance.new("ImageLabel", ToggleFrame)
        ri.Size = UDim2.new(0, 20, 0, 20)
        ri.Position = UDim2.new(1, -15, 0.5, 0)
        ri.AnchorPoint = Vector2.new(1, 0.5)
        ri.BackgroundTransparency = 1
        ri.Image = IconId
        ri.ImageColor3 = theme.Primary
        rightOffset = -45
    end

    local Title = Instance.new("TextLabel", ToggleFrame)
    Title.Size = UDim2.new(1, -120, 1, 0)
    Title.Position = UDim2.new(0, titleOffset, 0, 0)
    Title.BackgroundTransparency = 1
    Title.Text = TName
    Title.TextColor3 = theme.Text
    Title.Font = Enum.Font.GothamMedium
    Title.TextSize = 15
    Title.TextXAlignment = Enum.TextXAlignment.Left

    -- Toggle Visuals
    local Pill, Circle
    if TType == "box" then
        local Box = Instance.new("Frame", ToggleFrame)
        Box.Size = UDim2.new(0, 24, 0, 24)
        Box.Position = UDim2.new(1, rightOffset, 0.5, 0)
        Box.AnchorPoint = Vector2.new(1, 0.5)
        Box.BackgroundColor3 = Color3.fromRGB(15, 10, 8)
        Instance.new("UICorner", Box).CornerRadius = UDim.new(0, 6)
        local bs = Instance.new("UIStroke", Box)
        bs.Thickness = 1.5
        bs.Color = Color3.fromRGB(80, 80, 80)
        local Check = Instance.new("ImageLabel", Box)
        Check.Size = UDim2.new(0, 0, 0, 0)
        Check.AnchorPoint = Vector2.new(0.5, 0.5)
        Check.Position = UDim2.new(0.5, 0, 0.5, 0)
        Check.BackgroundTransparency = 1
        Check.Image = "rbxassetid://6257079049"
        Check.ImageColor3 = Color3.fromRGB(20, 15, 12)
        local function Update()
            if State then
                TweenService:Create(Box, TweenInfo.new(0.2), {BackgroundColor3 = theme.Primary}):Play()
                TweenService:Create(bs, TweenInfo.new(0.2), {Color = theme.Primary}):Play()
                TweenService:Create(Check, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0.8, 0, 0.8, 0)}):Play()
            else
                TweenService:Create(Box, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(15, 10, 8)}):Play()
                TweenService:Create(bs, TweenInfo.new(0.2), {Color = Color3.fromRGB(80, 80, 80)}):Play()
                TweenService:Create(Check, TweenInfo.new(0.2), {Size = UDim2.new(0, 0, 0, 0)}):Play()
            end
        end
        InteractBtn.MouseButton1Click:Connect(function() State = not State; Update(); Callback(State) end)
        Update()
    else
        Pill = Instance.new("Frame", ToggleFrame)
        Pill.Size = UDim2.new(0, 44, 0, 22)
        Pill.Position = UDim2.new(1, rightOffset, 0.5, 0)
        Pill.AnchorPoint = Vector2.new(1, 0.5)
        Pill.BackgroundColor3 = theme.ToggleOff
        Instance.new("UICorner", Pill).CornerRadius = UDim.new(1, 0)
        Circle = Instance.new("Frame", Pill)
        Circle.Size = UDim2.new(0, 18, 0, 18)
        Circle.Position = UDim2.new(0, 2, 0.5, 0)
        Circle.AnchorPoint = Vector2.new(0, 0.5)
        Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

        local function Update()
            local targetBg = State and theme.Primary or theme.ToggleOff
            local targetPos = State and UDim2.new(1, -20, 0.5, 0) or UDim2.new(0, 2, 0.5, 0)
            TweenService:Create(Pill, TweenInfo.new(0.3), {BackgroundColor3 = targetBg}):Play()
            TweenService:Create(Circle, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = targetPos}):Play()
        end

        -- Drag Right = ON with Lift Effect
        local dragging = false
        local dragStartPos = nil
        local originalPos = ToggleFrame.Position
        InteractBtn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStartPos = input.Position
                originalPos = ToggleFrame.Position
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - dragStartPos
                if delta.X > 5 then
                    -- Lift effect when dragging right
                    TweenService:Create(ToggleFrame, TweenInfo.new(0.15), {
                        Position = originalPos + UDim2.new(0, 0, 0, -6),
                        BackgroundTransparency = 0.3
                    }):Play()
                end
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
                dragging = false
                local delta = input.Position - dragStartPos
                -- Return to original position and opacity
                TweenService:Create(ToggleFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Position = originalPos,
                    BackgroundTransparency = 0
                }):Play()
                -- Determine state: if dragged right significantly OR circle is on the right side
                if delta.X > 15 then
                    State = true
                elseif delta.X < -15 then
                    State = false
                else
                    State = not State
                end
                Update()
                Callback(State)
            end
        end)
        Update()
    end

    InteractBtn.MouseEnter:Connect(function() TweenService:Create(ToggleFrame, TweenInfo.new(0.2), {BackgroundColor3 = theme.ElementHover}):Play() end)
    InteractBtn.MouseLeave:Connect(function() TweenService:Create(ToggleFrame, TweenInfo.new(0.2), {BackgroundColor3 = theme.ElementBg}):Play() end)

    ApplyLock(ToggleFrame, Options, theme)
    return ToggleFrame
end

-- ============================================================
-- ADD SLIDER (Drag Up = Lift Effect)
-- ============================================================
function KustUI:AddSlider(Tab, Options)
    local theme = self.Theme
    local Name = Options.Name or "Slider"
    local Min = Options.Min or 0
    local Max = Options.Max or 100
    local Default = Options.Default or Min
    local IconID = Options.Icon
    local Callback = Options.Callback or function() end

    local Container = Instance.new("Frame", Tab)
    Container.Size = UDim2.new(1, -20, 0, 50)
    Container.BackgroundTransparency = 1

    local Header = Instance.new("Frame", Container)
    Header.Size = UDim2.new(1, 0, 0, 20)
    Header.BackgroundTransparency = 1

    local titleOffset = 5
    if IconID then
        local Icon = Instance.new("ImageLabel", Header)
        Icon.Size = UDim2.new(0, 16, 0, 16)
        Icon.Position = UDim2.new(0, 5, 0.5, -8)
        Icon.BackgroundTransparency = 1
        Icon.Image = IconID
        Icon.ImageColor3 = theme.Primary
        titleOffset = 26
    end

    local TitleLabel = Instance.new("TextLabel", Header)
    TitleLabel.Size = UDim2.new(1, -60, 1, 0)
    TitleLabel.Position = UDim2.new(0, titleOffset, 0, 0)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = Name
    TitleLabel.TextColor3 = theme.Text
    TitleLabel.Font = Enum.Font.GothamMedium
    TitleLabel.TextSize = 13
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

    local ValueDisplay = Instance.new("TextLabel", Header)
    ValueDisplay.Size = UDim2.new(0, 40, 1, 0)
    ValueDisplay.Position = UDim2.new(1, -45, 0, 0)
    ValueDisplay.BackgroundTransparency = 1
    ValueDisplay.Text = tostring(Default)
    ValueDisplay.TextColor3 = theme.Primary
    ValueDisplay.Font = Enum.Font.GothamBold
    ValueDisplay.TextSize = 13
    ValueDisplay.TextXAlignment = Enum.TextXAlignment.Right

    local TrackArea = Instance.new("Frame", Container)
    TrackArea.Size = UDim2.new(1, -10, 0, 20)
    TrackArea.Position = UDim2.new(0, 5, 0, 25)
    TrackArea.BackgroundTransparency = 1

    local Track = Instance.new("Frame", TrackArea)
    Track.Size = UDim2.new(1, 0, 0, 4)
    Track.Position = UDim2.new(0, 0, 0.5, -2)
    Track.BackgroundColor3 = theme.TrackBg
    Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

    local Fill = Instance.new("Frame", Track)
    Fill.Size = UDim2.new((Default - Min) / (Max - Min), 0, 1, 0)
    Fill.BackgroundColor3 = theme.Primary
    Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

    local Thumb = Instance.new("ImageLabel", Track)
    Thumb.Size = UDim2.new(0, 32, 0, 18)
    Thumb.Position = UDim2.new((Default - Min) / (Max - Min), 0, 0.5, 0)
    Thumb.AnchorPoint = Vector2.new(0.5, 0.5)
    Thumb.BackgroundTransparency = 1
    Thumb.Image = "rbxassetid://125083578015333"
    Thumb.ImageColor3 = theme.Text
    Thumb.ScaleType = Enum.ScaleType.Fit

    local Dragging = false
    local TargetPct = (Default - Min) / (Max - Min)
    local CurrentPct = TargetPct
    local Mouse = Players.LocalPlayer:GetMouse()
    local originalContainerPos = Container.Position
    local liftActive = false

    Thumb.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            Dragging = true
            originalContainerPos = Container.Position
            TweenService:Create(Thumb, TweenInfo.new(0.2), {Size = UDim2.new(0, 36, 0, 22)}):Play()
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if Dragging then
                Dragging = false
                liftActive = false
                TweenService:Create(Thumb, TweenInfo.new(0.2), {Size = UDim2.new(0, 32, 0, 18)}):Play()
                -- Return to original position and opacity
                TweenService:Create(Container, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    Position = originalContainerPos,
                    BackgroundTransparency = 1
                }):Play()
            end
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if Dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local pos = math.clamp((Mouse.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
            TargetPct = pos
            -- Lift effect when dragging up slightly
            local deltaY = input.Position.Y - (Thumb.AbsolutePosition.Y + Thumb.AbsoluteSize.Y / 2)
            if deltaY < -10 and not liftActive then
                liftActive = true
                TweenService:Create(Container, TweenInfo.new(0.15), {
                    Position = originalContainerPos + UDim2.new(0, 0, 0, -4),
                    BackgroundTransparency = 0.85
                }):Play()
            elseif deltaY > -5 and liftActive then
                liftActive = false
                TweenService:Create(Container, TweenInfo.new(0.15), {
                    Position = originalContainerPos,
                    BackgroundTransparency = 1
                }):Play()
            end
        end
    end)

    RunService.RenderStepped:Connect(function()
        if Dragging or math.abs(TargetPct - CurrentPct) > 0.001 then
            CurrentPct = CurrentPct + (TargetPct - CurrentPct) * 0.4
            if math.abs(TargetPct - CurrentPct) < 0.001 then CurrentPct = TargetPct end
            Thumb.Position = UDim2.new(CurrentPct, 0, 0.5, 0)
            Fill.Size = UDim2.new(CurrentPct, 0, 1, 0)
            local val = math.floor(Min + (CurrentPct * (Max - Min)))
            ValueDisplay.Text = tostring(val)
            Callback(val)
        end
    end)

    ApplyLock(Container, Options, theme)
    return Container
end

