function KustUI:AddKeybind(Tab, Options)
    local theme = self.Theme
    local KName = Options.Name or "Keybind"
    local CurrentKey = Options.Default or Enum.KeyCode.RightShift
    local Callback = Options.Callback or function() end
    local IsListening = false
    local Connection = nil

    local KeybindFrame = Instance.new("Frame")
    KeybindFrame.Name = KName .. "_Keybind"
    KeybindFrame.Size = UDim2.new(1, -24, 0, 42)
    KeybindFrame.BackgroundColor3 = theme.ElementBg
    KeybindFrame.Parent = Tab
    Instance.new("UICorner", KeybindFrame).CornerRadius = UDim.new(0, 5)
    local ks = Instance.new("UIStroke", KeybindFrame)
    ks.Color = theme.Primary; ks.Thickness = 1; ks.Transparency = 0.8; ks.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    local Title = Instance.new("TextLabel", KeybindFrame)
    Title.Size = UDim2.new(0.5, 0, 1, 0)
    Title.Position = UDim2.new(0, 15, 0, 0)
    Title.BackgroundTransparency = 1
    Title.Text = KName
    Title.TextColor3 = theme.Text
    Title.Font = Enum.Font.GothamSemibold
    Title.TextSize = 14
    Title.TextXAlignment = Enum.TextXAlignment.Left

    local BindBox = Instance.new("TextButton", KeybindFrame)
    BindBox.Size = UDim2.new(0, 80, 0, 28)
    BindBox.Position = UDim2.new(1, -15, 0.5, 0)
    BindBox.AnchorPoint = Vector2.new(1, 0.5)
    BindBox.BackgroundColor3 = Color3.fromRGB(30, 20, 15)
    BindBox.Text = CurrentKey.Name
    BindBox.TextColor3 = theme.Primary
    BindBox.Font = Enum.Font.GothamBold
    BindBox.TextSize = 12
    Instance.new("UICorner", BindBox).CornerRadius = UDim.new(0, 5)
    local bs = Instance.new("UIStroke", BindBox)
    bs.Color = theme.Primary; bs.Transparency = 1

    local function StopListening()
        IsListening = false
        BindBox.Text = CurrentKey.Name
        TweenService:Create(bs, TweenInfo.new(0.2), {Transparency = 1}):Play()
        TweenService:Create(BindBox, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(30, 20, 15)}):Play()
        if Connection then Connection:Disconnect(); Connection = nil end
    end
    BindBox.MouseButton1Click:Connect(function()
        if IsListening then return end
        IsListening = true
        BindBox.Text = "..."
        TweenService:Create(bs, TweenInfo.new(0.2), {Transparency = 0}):Play()
        TweenService:Create(BindBox, TweenInfo.new(0.2), {BackgroundColor3 = theme.ElementBg}):Play()
        Connection = UserInputService.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                StopListening(); return
            end
            if Input.UserInputType == Enum.UserInputType.Keyboard then
                local key = Input.KeyCode
                if key == Enum.KeyCode.Backspace or key == Enum.KeyCode.Escape then
                    StopListening()
                else
                    CurrentKey = key; StopListening(); Callback(CurrentKey)
                end
            end
        end)
    end)

    ApplyLock(KeybindFrame, Options, theme)
    return KeybindFrame
end

