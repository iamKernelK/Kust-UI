    Layout.SortOrder = Enum.SortOrder.LayoutOrder
    Layout.Padding = UDim.new(0, 10)

    TabButton.MouseButton1Click:Connect(function()
        if TabContainer.Visible then return end
        for _, child in ipairs(self.ElementsMenu:GetChildren()) do
            if child:IsA("ScrollingFrame") then child.Visible = false end
        end
        for _, btn in ipairs(self.TabsMenu:GetChildren()) do
            if btn:IsA("TextButton") then
                TweenService:Create(btn, TweenInfo.new(0.25), {BackgroundColor3 = theme.Surface}):Play()
                local stroke = btn:FindFirstChild("UIStroke")
                if stroke then TweenService:Create(stroke, TweenInfo.new(0.25), {Transparency = 1}):Play() end
                local txt = btn:FindFirstChildOfClass("TextLabel")
                if txt then TweenService:Create(txt, TweenInfo.new(0.25), {TextColor3 = theme.TextDim}):Play() end
                local icon = btn:FindFirstChildOfClass("ImageLabel")
                if icon then TweenService:Create(icon, TweenInfo.new(0.25), {ImageColor3 = theme.TextDim}):Play() end
            end
